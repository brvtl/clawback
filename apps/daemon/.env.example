# Clawback Daemon Configuration

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=./clawback.db

# AI Engine — set ONE of these for skill/workflow execution
# Option 1: Anthropic API (per-token billing)
# ANTHROPIC_API_KEY=sk-ant-...
# Option 2: Claude Code OAuth (Claude Max subscription)
# The claude CLI handles auth internally — set to any value to enable SDK mode.
# CLAUDE_CODE_OAUTH_TOKEN=use-cli-auth
