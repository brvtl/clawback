# Clawback Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================

# Port for the daemon API server (default: 3000)
PORT=3000

# Host to bind to (default: localhost, use 0.0.0.0 for network access)
HOST=localhost

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ===================
# Database
# ===================

# Path to SQLite database (default: ./clawback.db)
# DATABASE_URL=./clawback.db

# ===================
# Skills
# ===================

# Directory containing skill definitions (default: ./skills)
# SKILLS_DIR=./skills

# ===================
# AI Engine (set ONE of these)
# ===================

# Option 1: Anthropic API key (per-token billing)
# Get one at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Claude Code OAuth token (Claude Max subscription)
# Uses the Agent SDK — bills against your Max plan instead of per-token
# The spawned claude CLI handles its own auth via ~/.claude/.credentials.json,
# so this value is only used to select the SDK engine. Set to any non-empty value
# (e.g., "use-cli-auth") on machines where the claude CLI is already logged in.
# CLAUDE_CODE_OAUTH_TOKEN=use-cli-auth

# ===================
# Security
# ===================

# Encryption key for sensitive data (tokens, passwords) stored in database
# Generate with: openssl rand -hex 32
# If not set, a machine-derived key is used (less secure, not portable)
# CLAWBACK_ENCRYPTION_KEY=your-64-char-hex-key-here
